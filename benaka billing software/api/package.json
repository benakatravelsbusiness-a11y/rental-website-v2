{
  "name": "benaka-billing-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute benaka-db --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute benaka-db --file=./schema.sql",
    "db:seed": "wrangler d1 execute benaka-db --local --file=./seed.sql"
  },
  "dependencies": {
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240529.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.60.0"
  }
}
